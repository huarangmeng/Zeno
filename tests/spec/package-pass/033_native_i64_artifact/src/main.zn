module main;

fn isHuge(value: I64) -> Bool {
    return value >= 4294967296;
}

fn classify(value: I64) -> I32 {
    val doubled: I64 = value * 2;
    val half: I64 = doubled / 2;
    if (isHuge(half)) {
        return 30;
    }
    if (half < 9) {
        return 6;
    }
    return 0;
}

fn main() -> I32 {
    val low: I64 = 8;
    val high: I64 = 4294967296;
    return classify(low) + classify(high);
}
