module main;

fn isLarge(value: U32) -> Bool {
    return value >= 10;
}

fn classify(value: U32) -> I32 {
    val doubled = value * 2;
    val half = doubled / 2;
    if (isLarge(half)) {
        return 30;
    }
    if (half < 7) {
        return 4;
    }
    return 0;
}

fn main() -> I32 {
    val low = 6;
    val high = 11;
    return classify(low) + classify(high);
}
