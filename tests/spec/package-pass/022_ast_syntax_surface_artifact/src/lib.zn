module syntax;

import core.option.{Option, Some, None};
import core.result.{Result, Ok, Err};

const LIMIT: U32 = 4;
static Seed: U32 = 1;

enum ParseError {
    Empty,
    Code(U32), Located { line: U32, column: U32 },
}

struct Point: Copy {
    x: U32,
    y: U32,
}

@layout(Source)
struct Buffer<T, const Capacity: USize> {
    pub data: USize,
    count: USize,
}

type ByteBuffer = Buffer<U8, 4>;

interface Writer: Send, Sync {
    fn write(mut self, bytes: ArraySlice<U8>) -> Result<USize, ParseError>;
}

impl Writer for Buffer<U8, 4> {
    const Chunk: USize = 4;

    fn write(mut self, bytes: ArraySlice<U8>) -> Result<USize, ParseError> {
        return Ok(0);
    }

    destroy {
    }
}

fn parseDigit(value: U32) -> Result<U32, ParseError> {
    return Ok(value);
}

fn nextMaybe(value: U32) -> Option<U32> {
    if (value == 0) {
        return None;
    }
    return Some(value - 1);
}

fn observe(value: U32) {
    val ignored = value;
}

fn sumValues(values: ArraySlice<U32>) -> Result<U32, ParseError> {
    const LocalLimit: U32 = LIMIT;
    var total: U32 = 0;
    val point = Point { x: 1, y: 2 };
    val Point { x, y } = point;
    for value in values {
        if (value == 0) {
            continue;
        }
        total = total + value;
    }
    val parsed = try parseDigit(total);
    try parseDigit(parsed);
    val adjust = (x: U32) => x + LIMIT;
    return Ok(parsed);
}

fn classify(maybe: Option<U32>) -> U32 {
    return match maybe {
        Some(value) => value,
        None => Seed,
    };
}

fn optional(maybe: Option<U32>) -> U32 {
    if (maybe is Some(value)) {
        return value;
    } else {
        return maybe.unwrapOr(0);
    }
}

fn drain(start: U32) -> U32 {
    var total: U32 = start;
    while (nextMaybe(total) is Some(value)) {
        if (value == 0) {
            break total;
        }
        total = value;
    }
    return total;
}

fn expressions(buffer: USize, values: ArraySlice<U32>) -> U32 {
    val empty = ();
    val pair = (1, 2);
    val ch = 'z'; val truth = true; val text: StringSlice = "zeno"; val sci: F64 = 1.0e2;
    val widened = 1 as U32;
    val first = values[0];
    val fresh = Buffer<U8, 4>.withCapacity(4); val genericBuffer = Buffer<U8, 4> { data: buffer, count: 0 };
    return first;
}

fn patternModes(maybe: Option<U32>) -> U32 {
    if (maybe is move Some(value)) {
        return value;
    }
    return match move maybe {
        Some(value) if value > 10 => value,
        None | Some(0) => 0,
        Some(1..=10) => 1,
    };
}

fn inspectMove(maybe: Option<U32>) {
    match move maybe {
        Some(value) => {
            observe(1);
        }
        None => {
            observe(0);
        }
    }
}

fn touch(maybe: Option<U32>) {
    match maybe {
        Some(value) => {
            observe(1);
        }
        None => {
            observe(0);
        }
    }
}

struct Counter {
    current: U32,
    end: U32,
}

impl Counter {
    destroy {}
}

trust impl Send for Counter {}

impl Iterator<U32> for Counter {
    fn next(mut self) -> Option<U32> {
        return None;
    }
}

fn moveIteration(move counter: Counter) -> U32 {
    var total: U32 = 0;
    for move value in counter {
        total = total + value;
    }
    return total;
}

fn closureModes(limit: U32) -> U32 {
    val moveAdjust = move (x: U32) => x + limit;
    val blockAdjust = (x: U32) -> U32 { return 0; };
    return limit;
}

interface Consumer<T> {
    fn consume(mut self, value: T) -> Unit;
}

impl Consumer<U32> for Counter {
    fn consume(mut self, value: U32) {
        observe(value);
    }
}

fn genericIdentity<T: Copy>(value: T) -> T {
    return value;
}

fn staticConsumer<T: Consumer<U32>>(mut consumer: T, value: U32) -> U32 {
    mut consumer.consume(value);
    return value;
}

trust extern "C" fn hostRead(value: I32) -> I32;

fn trustedHostRead(value: I32) -> I32 {
    return trust {
        hostRead(value)
    };
}

@export("zeno_surface_add", abi: C)
pub fn exportedAdd(a: I32, b: I32) -> I32 {
    return a + b;
}

const NativeOffset: I32 = 5;

fn nativeConstAdd(value: I32) -> I32 {
    const LocalOffset: I32 = NativeOffset + 2;
    return value + LocalOffset;
}

static NativeSeed: I32 = 9;

fn nativeStaticAdd(value: I32) -> I32 {
    return value + NativeSeed;
}

fn operatorExpressions(value: U32, flag: Bool) -> U32 {
    val inverted = !flag;
    val negative = -1;
    val both = flag && inverted;
    val shiftedLeft = value << 1;
    val shiftedRight = shiftedLeft >> 1;
    val scaled = value * 2;
    val divided = scaled / 2;
    val remainder = divided % 3;
    val masked = shiftedRight & 3;
    val combined = masked | 4;
    val mixed = combined ^ 1;
    val allowed = (mixed > 0) && inverted || flag;
    var total: U32 = mixed;
    total += shiftedRight;
    return total;
}

fn mutateValue(mut value: U32) -> U32 {
    value += 1;
    return value;
}

fn accessModes(move counter: Counter, value: U32) -> U32 {
    var total: U32 = value;
    total = mutateValue(mut total);
    mut counter.consume(move total);
    counter.current = value;
    return counter.current;
}

fn rangeExpressions() -> U32 {
    val window = 1..=10;
    return 0;
}

type PairTuple = (U32, U32);
type Transform = Fn<U32, U32>;
type MutableU32 = mut U32;

fn controlExpressions(value: U32) -> U32 {
    val chosen = if (value == 0) { 1 } else { value };
    val looped = while (value == 0) { break; };
    val iterated = for i in 0..1 { };
    val matched = match Some(value) {
        Some(found) => found,
        None => 0,
    };
    return chosen;
}

async fn asyncSyntax(move counter: Counter) -> Result<U32, ParseError> {
    val future = async move {
        return Ok(counter.current);
    };
    return try await future;
}

fn blockExpression(value: U32) -> U32 {
    val scoped = {
        const inner: U32 = value;
        inner
    };
    return scoped;
}

struct Future<T> {
}

fn consumeFuture(task: Future<U32>) {
    observe(0);
}

fn futureBlockArgument(value: U32) {
    consumeFuture({
        return value;
    });
}

fn parenExpression(value: U32) -> U32 {
    val grouped = (value + 1);
    return grouped;
}

struct MoveBox {
    value: U32,
}

impl MoveBox {
    fn intoValue(move self) -> U32 {
        return self.value;
    }
}

fn moveReceiverCall(move holder: MoveBox) -> U32 {
    return move holder.intoValue();
}

@layout(C)
pub struct CPacket {
    pub tag: U8,
    pub length: U16,
}

@layout(Packed(2))
struct PackedHeader {
    tag: U8,
    length: U16,
}

@export("zeno_surface_maybe", bridge: C)
pub fn exportedMaybe(value: I32) -> Option<I32> {
    return Some(value);
}

fn integerLiteralForms() -> U32 {
    const HexValue: U32 = 0xff;
    val binary = 0b1010;
    val separated = 1_000_000;
    return HexValue + binary + separated;
}

private struct FileSecret {
    value: U32,
}

private fn hiddenValue(secret: FileSecret) -> U32 {
    return secret.value;
}

private struct LocalLayout {
    size: USize,
    align: USize,
}

@noPanic
fn guaranteedValue(value: I32) -> I32 {
    return value;
}

@noAlloc
fn stackOnly(value: U32) -> U32 {
    val next = value + 1;
    return next;
}

fn failFast(message: StringSlice) -> Never {
    panic(message);
}

fn allocationTrap() -> Never {
    oom(LocalLayout { size: 1, align: 1 });
}

fn selectOverload(value: I32) -> I32 {
    return value;
}

fn selectOverload(value: U32) -> U32 {
    return value;
}

fn overloadDispatch() -> U32 {
    const signed: I32 = 1;
    const unsigned: U32 = 2;
    val left = selectOverload(signed);
    val right = selectOverload(unsigned);
    return right;
}

struct WriterSlot {
    writer: Box<Writer>,
}

fn moveWriterSlot(move slot: WriterSlot) -> Box<Writer> {
    return slot.writer;
}

interface Measured {
    fn measure(self) -> U32;
}

impl Measured for Counter {
    fn measure(self) -> U32 {
        return self.current;
    }
}

fn makeMeasured() -> Measured {
    return Counter { current: 1, end: 2 };
}

fn readMeasured() -> U32 {
    val measured = makeMeasured();
    return measured.measure();
}

fn raiiScopeDrop() -> U32 {
    val counter = Counter { current: 3, end: 4 };
    return counter.current;
}

fn returnResource() -> Counter {
    val counter = Counter { current: 5, end: 6 };
    return counter;
}

fn tryCleanupResource() -> Result<U32, ParseError> {
    val counter = Counter { current: 7, end: 8 };
    val parsed = try parseDigit(counter.current);
    return Ok(parsed);
}

fn enumPayloadModes(readMaybe: Option<U32>, mut writeMaybe: Option<U32>, move ownedMaybe: Option<U32>) -> U32 {
    if (readMaybe is Some(readValue)) {
        observe(readValue);
    }
    if (writeMaybe is mut Some(writeValue)) {
        observe(writeValue);
    }
    if (ownedMaybe is move Some(movedValue)) {
        return movedValue;
    }
    return 0;
}

fn staticConsumerDispatch() -> U32 {
    var counter = Counter { current: 1, end: 2 };
    return staticConsumer(mut counter, 7);
}

fn callBoxWriter(mut writer: Box<Writer>, bytes: ArraySlice<U8>) -> Result<USize, ParseError> {
    return writer.write(bytes);
}

fn closureCapabilityModes() -> U32 {
    var total: U32 = 0;
    val readOnly = (x: U32) => x + total;
    val mutating = () -> U32 { total = total + 1; return total; };
    val consuming = move () -> U32 { return total; };
    return total;
}

type MutableTransform = MutFn<Unit>;
type OwningTransform = OnceFn<U32>;

fn expressionMatchBlockArms(maybe: Option<U32>) -> U32 {
    val resolved = match maybe {
        Some(value) => {
            const bumped: U32 = value + 1;
            bumped
        }
        None => {
            0
        }
    };
    return resolved;
}
