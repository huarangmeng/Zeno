module main;

pub fn addIfPositive(value: I32, delta: I32) -> I32 {
    if (value > 0) {
        return value + delta;
    }
    return delta;
}

pub fn sumTo(limit: I32) -> I32 {
    var i: I32 = 0;
    var acc: I32 = 0;
    while (i < limit) {
        acc = acc + i;
        i = i + 1;
    }
    return acc;
}

pub fn main() -> I32 {
    const offset = 1;
    val total = sumTo(4);
    val result = addIfPositive(total, offset);
    return result;
}
