module main;

fn compound(value: I32) -> I32 {
    var total: I32 = value;
    total += 5;
    total *= 3;
    total -= 4;
    total /= 2;
    total %= 7;
    total |= 8;
    total &= 14;
    total ^= 3;
    total <<= 1;
    total >>= 1;
    return total;
}

fn negate(value: I32) -> I32 {
    return -value;
}

fn main() -> I32 {
    return compound(7) + negate(0);
}
