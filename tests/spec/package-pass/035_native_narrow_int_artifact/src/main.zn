module main;

fn isSmallSigned8(value: I8) -> Bool {
    return value < 9;
}

fn normalizeSigned8(value: I8) -> I8 {
    return value + 0;
}

fn classifySigned8(value: I8) -> I32 {
    val doubled = value * 2;
    val half = normalizeSigned8(doubled / 2);
    if (isSmallSigned8(normalizeSigned8(half))) {
        return 4;
    }
    return 0;
}

fn isSmallUnsigned8(value: U8) -> Bool {
    return value < 9;
}

fn normalizeUnsigned8(value: U8) -> U8 {
    return value + 0;
}

fn classifyUnsigned8(value: U8) -> I32 {
    val doubled = value * 2;
    val half = normalizeUnsigned8(doubled / 2);
    if (isSmallUnsigned8(normalizeUnsigned8(half))) {
        return 5;
    }
    return 0;
}

fn isLargeSigned16(value: I16) -> Bool {
    return value >= 300;
}

fn normalizeSigned16(value: I16) -> I16 {
    return value + 0;
}

fn classifySigned16(value: I16) -> I32 {
    val doubled = value * 2;
    val half = normalizeSigned16(doubled / 2);
    if (isLargeSigned16(normalizeSigned16(half))) {
        return 30;
    }
    return 0;
}

fn isLargeUnsigned16(value: U16) -> Bool {
    return value >= 300;
}

fn normalizeUnsigned16(value: U16) -> U16 {
    return value + 0;
}

fn classifyUnsigned16(value: U16) -> I32 {
    val doubled = value * 2;
    val half = normalizeUnsigned16(doubled / 2);
    if (isLargeUnsigned16(normalizeUnsigned16(half))) {
        return 40;
    }
    return 0;
}

fn main() -> I32 {
    val i8Value = 8;
    val u8Value = 8;
    val i16Value = 300;
    val u16Value = 300;
    return classifySigned8(i8Value) + classifyUnsigned8(u8Value) + classifySigned16(i16Value) + classifyUnsigned16(u16Value);
}
