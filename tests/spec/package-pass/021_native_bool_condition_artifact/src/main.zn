module main;

pub fn isPositive(value: I32) -> Bool {
    return value > 0;
}

pub fn answer() -> I32 {
    return 3;
}

pub fn pick(value: I32) -> I32 {
    const target = 0;
    if (isPositive(value - target)) {
        return 7;
    }
    return 1;
}

pub fn main() -> I32 {
    val base = answer();
    return pick(base);
}
