module main;

fn isHuge(value: U64) -> Bool {
    return value >= 4294967296;
}

fn classify(value: U64) -> I32 {
    val doubled: U64 = value * 2;
    val half: U64 = doubled / 2;
    if (isHuge(half)) {
        return 30;
    }
    if (half < 9) {
        return 5;
    }
    return 0;
}

fn main() -> I32 {
    val low: U64 = 8;
    val high: U64 = 4294967296;
    return classify(low) + classify(high);
}
