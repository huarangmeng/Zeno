module main;

fn isHuge(value: U64) -> Bool {
    return value >= 4294967296;
}

fn normalize(value: U64) -> U64 {
    return value + 0;
}

fn classify(value: U64) -> I32 {
    val doubled = value * 2;
    val half = normalize(doubled / 2);
    if (isHuge(normalize(half))) {
        return 30;
    }
    if (half < 9) {
        return 5;
    }
    return 0;
}

fn main() -> I32 {
    val low = 8;
    val high = 4294967296;
    return classify(low) + classify(high);
}
