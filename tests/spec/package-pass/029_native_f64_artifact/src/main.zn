module main;

fn isLarge(value: F64) -> Bool {
    return value > 3.500000;
}

fn classify(value: F64) -> I32 {
    val scaled: F64 = value * 2.000000;
    val pivot: F64 = 2.5;
    if (isLarge(scaled)) {
        return 40;
    }
    if (scaled > pivot) {
        return 2;
    }
    return 0;
}

fn main() -> I32 {
    val low: F64 = 1.5;
    val high: F64 = 4.0;
    return classify(low) + classify(high);
}
