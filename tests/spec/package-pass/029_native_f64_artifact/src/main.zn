module main;

fn isLarge(value: F64) -> Bool {
    return value > 3.500000;
}

fn scale(value: F64) -> F64 {
    return value * 2.000000;
}

fn classify(value: F64) -> I32 {
    val scaled = scale(value);
    val pivot = 2.5;
    if (isLarge(scale(value))) {
        return 40;
    }
    if (scaled > pivot) {
        return 2;
    }
    return 0;
}

fn main() -> I32 {
    val low = 1.5;
    val high = 4.0;
    return classify(low) + classify(high);
}
