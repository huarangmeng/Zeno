module main;

fn isWideSize(value: USize) -> Bool {
    return value >= 4294967296;
}

fn normalizeSize(value: USize) -> USize {
    return value + 0;
}

fn classifySize(value: USize) -> I32 {
    val doubled = value * 2;
    val half = normalizeSize(doubled / 2);
    if (isWideSize(normalizeSize(half))) {
        return 30;
    }
    if (half < 9) {
        return 7;
    }
    return 0;
}

fn isWideOffset(value: ISize) -> Bool {
    return value >= 4294967296;
}

fn normalizeOffset(value: ISize) -> ISize {
    return value + 0;
}

fn classifyOffset(value: ISize) -> I32 {
    val doubled = value * 2;
    val half = normalizeOffset(doubled / 2);
    if (isWideOffset(normalizeOffset(half))) {
        return 40;
    }
    if (half < 9) {
        return 8;
    }
    return 0;
}

fn main() -> I32 {
    val sizeLow = 8;
    val sizeHigh = 4294967296;
    val offsetLow = 8;
    val offsetHigh = 4294967296;
    return classifySize(sizeLow) + classifySize(sizeHigh) + classifyOffset(offsetLow) + classifyOffset(offsetHigh);
}
