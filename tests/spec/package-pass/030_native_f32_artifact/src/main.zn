module main;

fn isWide(value: F32) -> Bool {
    return value > 3.500000;
}

fn classify(value: F32) -> I32 {
    val squared = value * value;
    val pivot = 1.250000;
    if (isWide(squared)) {
        return 30;
    }
    if (squared > pivot) {
        return 5;
    }
    return 0;
}

fn main() -> I32 {
    val low = 1.500000;
    val high = 2.000000;
    return classify(low) + classify(high);
}
