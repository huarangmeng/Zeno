// category: compile-fail
// profile: freestanding
// purpose: constant out-of-bounds indexing is rejected

module tests.fail.constOobIndex;

import core.alloc.{AllocError, GlobalAllocator};
import core.result.{Result, Ok};

fn main(mut allocator: GlobalAllocator) -> Result<Unit, AllocError> {
    let bytes = Array<U8>.filledIn(4, 0, mut allocator);
    let value = bytes[4]; // expected-error: constant index is out of bounds
    return Ok(());
}
