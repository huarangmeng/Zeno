// category: compile-fail
// stage: mvp
// milestone: M4
// profile: freestanding
// purpose: move parameters require explicit call-site move for named non-Copy arguments

module tests.fail.moveParameterRequiresMove;

struct Handle {
    id: U32,
}

impl Handle {
    destroy {}
}

fn consume(move handle: Handle) {}

fn main() {
    val handle = Handle { id: 1 };
    consume(handle); // expected-error[E0402]: move parameter requires explicit `move` at call site
}
