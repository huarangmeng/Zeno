// category: compile-fail
// stage: mvp
// milestone: M3
// profile: freestanding
// purpose: try does not implicitly convert Option into Result

module tests.fail.tryOptionInResult;

import core.option.Option;
import core.result.{Result, Ok};

enum ParseError {
    OutOfRange,
}

fn bad(value: U32) -> Result<U8, ParseError> {
    val byte = try U8.fromChecked(value); // expected-error[E0301]: try on Option in Result function requires explicit okOr or okOrElse
    return Ok(byte);
}
