// category: compile-fail
// stage: mvp
// milestone: M4
// profile: freestanding
// purpose: access to local storage cannot escape

module tests.fail.returnLocalAccess;

import core.alloc.{AllocError, GlobalAllocator};
import core.result.{Result, Ok};

fn bad(mut allocator: GlobalAllocator) -> Result<ArraySlice<U8>, AllocError> {
    val local = Array<U8>.filledIn(4, 0, mut allocator);
    return Ok(local); // expected-error[E0502]: returns slice to local storage
}
