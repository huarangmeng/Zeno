// category: compile-fail
// profile: freestanding
// purpose: self methods consume their receiver

module tests.fail.useAfterMoveSelf;

struct Counter {
    value: U32,
}

impl Counter {
    fn get(self) -> U32 {
        return self.value;
    }

    fn finish(move self) -> U32 {
        return self.value;
    }
}

fn main() {
    var counter = Counter { value: 1 };
    val done = move counter.finish();
    val late = counter.get(); // expected-error: receiver used after move self call
    val ignored = done + late;
}
