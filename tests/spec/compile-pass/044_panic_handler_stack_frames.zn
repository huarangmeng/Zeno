// category: compile-pass
// profile: hosted
// purpose: panic handlers can inspect source location and lazily iterate stack frames

module tests.pass.panicHandlerStackFrames;

import core.panic.PanicInfo;

fn countFrames(info: PanicInfo) -> USize {
    val message = info.message();
    val location = info.location();
    val file = location.file();
    val function = location.function();
    val line = location.line();
    val column = location.column();

    val ignoredMessage = message;
    val ignoredFile = file;
    val ignoredFunction = function;
    val ignoredLine = line;
    val ignoredColumn = column;

    var frames = info.stack();
    var count: USize = 0;

    for move frame in frames {
        val ip = frame.instructionPointer();
        val ra = frame.returnAddress();
        val symbol = frame.symbol();
        val ignoredIp = ip;
        val ignoredRa = ra;
        val ignoredSymbol = symbol;
        count = count + 1;
    }

    return count;
}
