// category: compile-pass
// profile: hosted
// purpose: spawnWithContext can provide TaskContext for explicit cancellation checks

module tests.pass.taskContextCancelCheck;

async fn runCancellable(move runtime: Runtime, move work: Work) -> Result<Unit, WorkError> {
    val task = try runtime.spawnWithContext(
        (ctx: TaskContext) {
            if (ctx.isCancellationRequested()) {
                return Err(WorkError.Cancelled);
            }

            return process(move work);
        }
    );

    return try await task;
}
