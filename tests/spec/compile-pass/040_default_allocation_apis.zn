// category: compile-pass
// stage: mvp
// milestone: M4
// profile: hosted
// purpose: hosted code can use profile default allocator through allocation APIs without In suffix

module tests.pass.defaultAllocationApis;

struct Packet {
    value: U8,
}

fn main() {
    val page = Array<U8>.filled(4, 0);
    var bytes = Vector<U8>.withCapacity(4);
    mut bytes.push(1);

    val boxed = Box.new(Packet { value: 2 });
    val shared = Shared.new(Packet { value: 3 });
    val text = String.from("hello");

    val ignoredPage = page;
    val ignoredBytes = bytes;
    val ignoredBox = boxed;
    val ignoredShared = shared;
    val ignoredText = text;
}
