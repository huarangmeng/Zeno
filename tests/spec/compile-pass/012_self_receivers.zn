// category: compile-pass
// stage: mvp
// milestone: M4
// profile: freestanding
// purpose: self, mut self, and move self follow receiver access rules

module tests.pass.selfReceivers;

struct Counter {
    value: U32,
}

impl Counter {
    fn get(self) -> U32 {
        return self.value;
    }

    fn bump(mut self) {
        self.value = self.value + 1;
    }

    fn finish(move self) -> U32 {
        return self.value;
    }
}

fn main() {
    var counter = Counter { value: 1 };
    val before = counter.get();
    mut counter.bump();
    val after = move counter.finish();
    val ignored = before + after;
}
