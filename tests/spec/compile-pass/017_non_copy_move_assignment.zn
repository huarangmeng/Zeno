// category: compile-pass
// stage: mvp
// milestone: M4
// profile: freestanding
// purpose: non-Copy owners move on assignment into an owning binding

module tests.pass.nonCopyMoveAssignment;

struct Handle {
    id: U32,
}

impl Handle {
    destroy {}
}

fn consume(move handle: Handle) -> U32 {
    return handle.id;
}

fn main() {
    val handle = Handle { id: 1 };
    val moved = handle;
    val id = consume(move moved);
    val ignored = id;
}
