// category: compile-pass
// profile: freestanding
// purpose: Box<Interface> owns a concrete value and dispatches through the interface table

module tests.pass.boxInterfaceDispatch;

import core.alloc.GlobalAllocator;
import core.result.{Result, Ok};

enum WriteError {
    Failed,
}

interface Writer {
    fn write(mut self, bytes: ArraySlice<U8>) -> Result<USize, WriteError>;
}

struct Counter {
    total: USize,
}

impl Writer for Counter {
    fn write(mut self, bytes: ArraySlice<U8>) -> Result<USize, WriteError> {
        self.total = self.total + bytes.len;
        return Ok(bytes.len);
    }
}

fn makeWriter(mut allocator: GlobalAllocator) -> Box<Writer> {
    val counter = Counter { total: 0 };
    return Box.newIn(move counter, mut allocator);
}

fn writeBox(mut writer: Box<Writer>, bytes: ArraySlice<U8>) -> Result<USize, WriteError> {
    return mut writer.write(bytes);
}
