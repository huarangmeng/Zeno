// category: compile-pass
// stage: mvp
// milestone: M4
// profile: freestanding
// purpose: non-Copy resource moves once and drops once

module tests.pass.moveRaii;

struct Handle {
    id: U32,
}

impl Handle {
    destroy {}
}

fn makeHandle() -> Handle {
    return Handle { id: 7 };
}

fn consume(move handle: Handle) {
    val ignoredId = handle.id;
}

fn main() {
    val handle = makeHandle();
    consume(move handle);
}
