// category: compile-pass
// stage: mvp
// milestone: M3
// profile: freestanding
// purpose: non-escaping closure captures Copy value without allocation

module tests.pass.closureNoEscape;

fn apply(value: I32, f: Fn<I32, I32>) -> I32 {
    return f(value);
}

fn callTwice(mut f: MutFn<Unit>) {
    f();
    f();
}

fn consumeOnce(move f: OnceFn<U64>) -> U64 {
    return f();
}

struct Token {
    value: U64,
}

fn take(move token: Token) -> U64 {
    return token.value;
}

fn main() {
    val bias = 10;
    val shortResult = apply(5, (x: I32) => x + bias);
    val blockResult = apply(5, (x: I32) -> I32 {
        return x * 2;
    });

    var count = 0;
    var inc = () {
        count = count + 1;
    };
    callTwice(mut inc);

    val token = Token { value: 9 };
    val movedValue = consumeOnce(move () -> U64 {
        return take(move token);
    });

    val ignoredCopy = shortResult + blockResult + count;
    val ignoredMove = movedValue;
}
