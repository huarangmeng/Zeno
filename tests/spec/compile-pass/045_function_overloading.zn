// category: compile-pass
// stage: mvp
// milestone: M3
// profile: freestanding
// purpose: overloads resolve by arity, parameter type, mut access mode, and generic specificity

module tests.pass.functionOverloading;

struct Packet {
    value: I32,
}

impl Packet {
    destroy {}
}

fn code(value: I32) -> I32 {
    return value + 1;
}

fn code(value: I64) -> I64 {
    return value + 1;
}

fn code(value: I32, extra: I32) -> I32 {
    return value + extra;
}

fn inspect(packet: Packet) -> I32 {
    return packet.value;
}

fn inspect(mut packet: Packet) -> I32 {
    packet.value = packet.value + 1;
    return packet.value;
}

fn archive(move packet: Packet) -> I32 {
    return packet.value;
}

fn identity<T: Copy>(value: T) -> T {
    return value;
}

fn identity(value: I32) -> I32 {
    return value + 10;
}

fn main() -> I32 {
    val small: I32 = 1;
    val wide: I64 = 2;
    var packet = Packet { value: 7 };

    val exact = code(small);
    val ignoredWide = code(wide);
    val arity = code(1, 2);
    val read = inspect(packet);
    val written = inspect(mut packet);
    val owned = archive(move packet);
    val specific = identity(small);
    val generic = identity(true);

    if (generic) {
        return exact + arity + read + written + owned + specific;
    }

    return 0;
}
