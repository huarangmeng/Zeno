// category: compile-pass
// profile: hosted
// purpose: string literals are StringSlice and owned strings use explicit String.from

module tests.pass.stringLiteralAndStringFrom;

const greeting: StringSlice = "hello";

fn textLen(text: StringSlice) -> USize {
    return text.len;
}

fn byteLen(text: StringSlice) -> USize {
    return text.asBytes().len;
}

fn owned() -> String {
    val text = String.from("hello");
    return text;
}

fn append() -> String {
    var text = String.from("zeno");
    mut text.push(" language");
    return text;
}

fn countChars(text: StringSlice) -> USize {
    var count: USize = 0;
    val chars = text.chars();
    for move ch in chars {
        val ignored = ch;
        count = count + 1;
    }
    return count;
}

fn main() {
    val view = "literal";
    val a = textLen(greeting) + textLen(view);
    val b = byteLen("bytes");
    val c = countChars("chars");
    val ownedText = owned();
    val appendedText = append();
    val ignored = a + b + c;
    val ignoredOwned = ownedText;
    val ignoredAppended = appendedText;
}
