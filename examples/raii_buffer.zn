module examples.raiiBuffer;

import core.alloc.GlobalAllocator;

struct Page {
    bytes: Array<U8>,
}

impl Page {
    fn new(mut allocator: GlobalAllocator) -> Page {
        let bytes = Array<U8>.filledIn(4096, 0, mut allocator);
        return Page { bytes: move bytes };
    }
}

fn consumePage(move page: Page) {
    // page is destroyed at the end of this function.
}

pub fn demo(mut allocator: GlobalAllocator) {
    let page = Page.new(mut allocator);
    consumePage(move page);
}
